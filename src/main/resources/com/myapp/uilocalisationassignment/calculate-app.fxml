<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>
<VBox fx:id="rootVBox" alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.myapp.uilocalisationassignment.AppController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <ComboBox onAction="#handleLanguageChange">
        <items>
            <FXCollections fx:factory="observableArrayList">
                <String fx:value="en"/>
                <String fx:value="fr"/>
                <String fx:value="jp"/>
                <String fx:value="ir"/>
            </FXCollections>
        </items>
        <value>en</value>
    </ComboBox>
    <Label fx:id="tripDistanceText"/>
    <TextField fx:id="tripDistanceInput"/>
    <Label fx:id="fuelConsumptionRateText"/>
    <TextField fx:id="fuelConsumptionRateInput"/>
    <Label fx:id="fuelCostText"/>
    <TextField fx:id="fuelCostInput"/>
    <Button fx:id="btnCalculate" text="calculateButton" onAction="#handleCalculate"/>
    <Label fx:id="resultText"/>
</VBox>
